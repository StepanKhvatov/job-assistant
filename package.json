{
  "name": "job-assistant",
  "version": "0.1.0",
  "description": "Personal AI-assisted job search assistant (HH.ru, Telegram, semi-auto apply)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "prisma generate",
    "db:migrate": "node scripts/run-with-direct-url.mjs migrate dev",
    "db:migrate:deploy": "node scripts/run-with-direct-url.mjs migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:verify": "tsx scripts/verify-db-schema.ts",
    "db:cleanup": "tsx scripts/db-cleanup.ts",
    "hh:sync": "tsx scripts/hh-sync-once.ts",
    "playwright:auth": "playwright test --project=setup",
    "playwright:apply": "playwright test --project=scrape apply.scrape",
    "hh:run": "npm run playwright:auth && npm run hh:scrape",
    "hh:scrape": "tsx scripts/hh-scrape-once.ts",
    "ai:rank": "tsx scripts/ai-rank-once.ts",
    "hh:apply": "tsx scripts/hh-apply-once.ts",
    "hh:pipeline": "npm run hh:scrape && npm run ai:rank && npm run hh:apply"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StepanKhvatov/job-assistant.git"
  },
  "license": "ISC",
  "dependencies": {
    "@fastify/env": "^6.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  }
}
