# Supabase → Project Settings → Database
# Runtime: Transaction pooler (port 6543, ?pgbouncer=true)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Migrations: Session pooler (port 5432) — из Dashboard → Connect → Session mode
# Не используйте transaction pooler (6543) для migrate
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Protect cron/worker endpoints (GitHub Actions)
CRON_SECRET=change-me-to-random-string

# --- HeadHunter (public API) ---
# Обязательно: User-Agent с email (требование hh.ru)
HH_USER_AGENT=job-assistant/1.0 (you@email.com)

# Токен приложения: https://dev.hh.ru/admin → приложение → access_token
HH_ACCESS_TOKEN=

# Ключевые слова через запятую → в поиске OR: (A) OR (B) OR (C)
HH_KEYWORDS=Frontend,React,TypeScript

# Либо полная строка поиска (перекрывает HH_KEYWORDS):
# HH_SEARCH_TEXT="Frontend разработчик"

HH_BASE_URL=https://api.hh.ru
HH_MAX_PAGES_PER_QUERY=5
HH_DETAIL_DELAY_MS=350
HH_INCLUDE_OFFICE=true
HH_INCLUDE_REMOTE=true
HH_MAX_VACANCIES_DETAIL=200

# --- Playwright scraping (соискатель, без API) ---
HH_EMAIL=
HH_PASSWORD=
HH_SCRAPE_BASE_URL=https://novosibirsk.hh.ru
HH_AUTH_STATE_PATH=.auth/hh-user.json
HH_AUTH_META_PATH=.auth/hh-session.meta.json
# Одна фраза для URL ?text= (пробелы и кириллица кодируются автоматически)
HH_SCRAPE_KEYWORD=Frontend разработчик
# Устаревший fallback: первое слово из списка через запятую
# HH_SCRAPE_KEYWORDS=Frontend,React,TypeScript
HH_SCRAPE_MAX_PAGES=3
HH_SCRAPE_MAX_VACANCIES=50
HH_SCRAPE_DETAIL_DELAY_MS=800
HH_SCRAPE_HEADLESS=true

# --- Stage 3: DeepSeek ranking ---
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# AI_RANK_LIMIT=20
# AI_RANK_DELAY_MS=500

# Retention: удаление старых vacancies (analyses каскадом)
VACANCY_RETENTION_DAYS=45
# VACANCY_RETENTION_ENABLED=false

# --- Auto-apply (Playwright) ---
APPLY_MIN_SCORE=75
APPLY_MAX_PER_RUN=5
APPLY_DELAY_MS=3000
# true = заполнить форму, не отправлять. false = реальный отклик.
APPLY_DRY_RUN=true

# Опционально позже:
# TELEGRAM_BOT_TOKEN=
